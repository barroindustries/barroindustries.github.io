rules_version = '2';

// ═══════════════════════════════════════════════════════════════════
//  BARRO INDUSTRIES — Cloud Storage Security Rules
//
//  SECURITY MODEL
//  --------------
//  • Deny by default. Nothing is readable or writable unless a rule
//    below explicitly allows it.
//  • Every read and write requires an authenticated user.
//  • ROLE / DEPARTMENT SCOPING via custom claims. Storage rules cannot
//    read Firestore, so the syncUserClaims Cloud Function mints each
//    user's role + departments onto their Auth token. We read them here
//    as request.auth.token.role / request.auth.token.departments:
//      – Finance/payslips (transfer proofs)  → finance tier ONLY.
//      – Other Finance/* (receipts, ledger, taxes, collections, …) →
//        readable/modifiable by internal staff, NOT the external
//        partner; overwrite/delete restricted to the finance tier so a
//        non-finance staffer can file a receipt but can't tamper with
//        or destroy existing financial files.
//      – Other department folders → internal staff only (the external
//        Brilliant Steel partner is excluded), with the partner still
//        allowed into folders that ARE one of their own departments.
//      – profile-photos stay owner-scoped; tasks/posts/General stay
//        collaborative (company-wide).
//
//  WHY "internal (non-partner)" RATHER THAN STRICT PER-DEPT MEMBERSHIP
//  ------------------------------------------------------------------
//  Many first-path segments are NOT real department keys — "General"
//  (All Company Files), Government-Biddings section titles, tasks,
//  posts. A strict "members of that department only" gate would deny
//  legitimate internal uploads/reads to those folders and break the
//  app. The concrete threat closed here is the EXTERNAL partner role
//  reading/overwriting/deleting internal (esp. financial) files, plus
//  locking payslip transfer proofs to finance.
//
//  NOTE ON DOWNLOAD URLS: getDownloadURL() is a READ. After an upload
//  the app immediately fetches the file's URL, so the uploader must
//  retain read on that path. Expense receipts are uploaded by internal
//  staff (non-partner) into Finance/* — covered by the "internal read"
//  rule. Payslip proofs are uploaded only by finance — covered by the
//  finance-tier rule. So no legitimate upload flow is broken.
//
//  PATHS IN USE (see js/drive.js, js/departments.js, js/app.js)
//  ------------------------------------------------------------
//    profile-photos/{uid}                       — uploadProfilePhoto
//    task-comments/{docId}/{file}               — task comment files
//    Finance/payslips/{file}                    — payslip transfer proofs
//    Finance/{Receipts|Taxes|Ledger|…}/{file}   — financial docs
//    {department}/{subfolder}/{file}            — dept uploads, gov, Files
//    tasks|posts|General/{subfolder}/{file}     — collaborative
// ═══════════════════════════════════════════════════════════════════

service firebase.storage {
  match /b/{bucket}/o {

    // ── Auth + size helpers ──────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }
    function isValidImage() {
      return request.resource.size <= 15 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
    function isValidDocument() {
      return request.resource.size <= 25 * 1024 * 1024;
    }

    // ── Custom-claim accessors (minted by syncUserClaims) ──
    // A missing custom claim reads as null on the token (it does NOT throw,
    // unlike a missing Firestore field), so scalar comparisons are safe. The
    // `departments` claim is a list — guard against null before `in`.
    function claimRole() {
      return request.auth.token.role;
    }
    function hasClaimDept(dept) {
      return request.auth.token.departments != null
        && dept in request.auth.token.departments;
    }
    function isAdminClaim() {
      return claimRole() == 'president' || claimRole() == 'manager';
    }
    // Finance tier mirrors firestore.rules isFinanceOrAdmin() + Finance-dept.
    function isFinanceClaim() {
      return claimRole() == 'president'
        || claimRole() == 'manager'
        || claimRole() == 'finance'
        || hasClaimDept('Finance');
    }
    function isPartnerClaim() {
      return claimRole() == 'partner';
    }
    // A user may reach a department folder if they're an admin, or it's one of
    // their own departments.
    function isMemberOf(dept) {
      return isAdminClaim() || hasClaimDept(dept);
    }

    // Top-level segments handled by their own dedicated rules below; the broad
    // {department} rule must EXCLUDE them, because Firebase unions (ORs)
    // overlapping matches — a broad allow would otherwise loosen the strict
    // ones (e.g. let a non-finance user read Finance/payslips).
    function isReservedTop(seg) {
      return seg == 'Finance'
        || seg == 'tasks' || seg == 'posts'
        || seg == 'general' || seg == 'General'
        || seg == 'profile-photos' || seg == 'task-comments'
        || seg == 'chat-files';
    }

    // ── Profile photos — owner-scoped writes ─────────
    // Anyone signed in may read (avatars appear app-wide); only the owning uid
    // may upload/replace/delete, and uploads must be valid images.
    match /profile-photos/{uid}/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn()
        && request.auth.uid == uid
        && (request.resource == null || isValidImage());
    }
    match /profile-photos/{uid} {
      allow read: if isSignedIn();
      allow write: if isSignedIn()
        && request.auth.uid == uid
        && (request.resource == null || isValidImage());
    }

    // ── Worker ID photos — HR-uploaded (WS27; NOT uid-owned, worker has no auth uid) ──
    // Read: any signed-in staff (photo shows on the ID card + verify page).
    // Write: finance tier only (HR uploads on the worker's behalf); valid image.
    // Note: getDownloadURL() on this path returns a token-bearing URL that gets
    // stored in the PUBLIC id_verify.photoUrl — intentional, the ID photo is
    // public-by-design (printed on a physical card, shown on the verify page).
    match /worker-id-photos/{profileId}/{allPaths=**} {
      allow read:  if isSignedIn();
      allow write: if isSignedIn() && isFinanceClaim()
        && (request.resource == null || isValidImage());
    }

    // ── Task comment attachments (collaborative) ─────
    match /task-comments/{docId}/{fileName} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (request.resource == null || isValidDocument());
      allow update, delete: if isSignedIn() && isOwnerOrAdmin();
    }

    // ── Team Chat attachments (v12 WS37) ─────────────
    // Storage rules cannot read Firestore, so per-conversation participant
    // checks are impossible here. Model: access truth lives on the Firestore-
    // gated message doc that carries the URL. Direct GET is open to any
    // signed-in user, but LIST is forbidden — DM conversation ids are
    // derivable from uids (dm_{a}_{b}), so enumeration must be blocked; the
    // Date.now()-prefixed filename keeps full paths unguessable.
    match /chat-files/{convId}/{fileName} {
      allow get:  if isSignedIn();
      allow list: if false;
      allow create: if isSignedIn() && (request.resource == null || isValidDocument());
      allow update, delete: if isSignedIn() && isOwnerOrAdmin();
    }

    // ── Finance / payslips — transfer proofs (crown jewels) ──
    // Bank screenshots of worker pay. Finance tier only, for read AND write.
    // Created exclusively by finance, so the post-upload getDownloadURL() the
    // app performs is done by a user who already has read.
    match /Finance/payslips/{fileName} {
      allow read: if isSignedIn() && isFinanceClaim();
      allow write: if isSignedIn() && isFinanceClaim()
        && (request.resource == null || isValidDocument());
    }

    // ── Finance / everything else (receipts, taxes, ledger, …) ──
    // (subfolder != 'payslips' so this never loosens the rule above.)
    //  • read  → internal staff (non-partner). Lets an employee retrieve the
    //            URL of the receipt they just filed; blocks the partner.
    //  • create (new object) → internal staff. Employees file expense receipts.
    //  • overwrite/delete (existing object) → finance tier only — a non-finance
    //    staffer can add a file but can't tamper with or destroy existing ones.
    match /Finance/{subfolder}/{fileName} {
      allow read: if isSignedIn() && subfolder != 'payslips' && !isPartnerClaim();
      allow write: if isSignedIn() && subfolder != 'payslips' && !isPartnerClaim()
        && (request.resource == null || isValidDocument())   // size cap on writes
        && (resource == null || isFinanceClaim());           // overwrite/delete → finance
    }

    // ── Collaborative, company-wide folders ──────────
    // Task/post attachments, the "All Company Files" tab (dept 'General') and
    // generic support-document uploads — readable/writable by any signed-in
    // user by design.
    // Ownership on update/delete (H4): the uploader or an admin may overwrite
    // or destroy an existing object. Legacy blobs (uploaded before this
    // metadata existed) carry no 'uploadedBy' key at all — 'x in map.keys()'
    // is the documented Storage-rules-safe way to test key presence without
    // throwing, so legacy objects fall through to admin-only.
    function isOwnerOrAdmin() {
      return isAdminClaim()
        || ('uploadedBy' in resource.metadata.keys()
              && resource.metadata.uploadedBy == request.auth.uid);
    }

    match /tasks/{subfolder}/{fileName} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (request.resource == null || isValidDocument());
      allow update, delete: if isSignedIn() && isOwnerOrAdmin();
    }
    match /posts/{subfolder}/{fileName} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (request.resource == null || isValidDocument());
      allow update, delete: if isSignedIn() && isOwnerOrAdmin();
    }
    match /general/{subfolder}/{fileName} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (request.resource == null || isValidDocument());
      allow update, delete: if isSignedIn() && isOwnerOrAdmin();
    }
    match /General/{subfolder}/{fileName} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (request.resource == null || isValidDocument());
      allow update, delete: if isSignedIn() && isOwnerOrAdmin();
    }

    // ── Other department folders ─────────────────────
    // Sales, Marketing, Design, IT, Admin, Production, Brilliant Steel, plus
    // gov-section-title and Files-tab folders. Internal staff get full
    // cross-department access; the external partner is excluded UNLESS the
    // folder is one of their own departments (e.g. their Brilliant Steel space).
    // Reserved top-level segments are excluded so their stricter rules win.
    match /{department}/{subfolder}/{fileName} {
      allow read: if isSignedIn()
        && !isReservedTop(department)
        && (!isPartnerClaim() || isMemberOf(department));
      allow create: if isSignedIn()
        && !isReservedTop(department)
        && (request.resource == null || isValidDocument())
        && (!isPartnerClaim() || isMemberOf(department));
      allow update, delete: if isSignedIn()
        && !isReservedTop(department)
        && (!isPartnerClaim() || isMemberOf(department))
        && isOwnerOrAdmin();
    }

    // ── Deny everything else by default ──────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Auth helpers ───────────────────────────────────
    function isAuth()         { return request.auth != null; }
    function isOwner(uid)     { return request.auth.uid == uid; }

    // Null-safe role lookup. Reading `.data.role` directly THROWS (and denies the
    // rule) when the user doc or the `role` field is absent — which legitimately
    // happens for freshly-created / worker / older profiles. .get('role', null)
    // degrades to null instead, so callers can treat "no role" as "not privileged"
    // and "not partner" rather than being hard-denied. Returns null when missing.
    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', null);
    }
    // 'secretary' (Corporate Secretary) is an admin-portal oversight role with
    // manager-level access. It is intentionally NOT in isPresident(), so deletions of
    // key records (finance, payroll, ledger — all gated on isPresident below) still
    // require the President's approval, exactly as for managers.
    function isAdmin()          { return getRole() in ['president', 'manager', 'secretary']; }
    function isFinanceOrAdmin() { return getRole() in ['president', 'manager', 'secretary', 'finance']; }
    function isPresident()      { return getRole() == 'president'; }
    // v12 WS19 — secretary two-tier: secretary keeps isAdmin()/isFinanceOrAdmin()
    // for the minor/oversight surface (memos, SOPs, sign-ups, minor approvals),
    // but money-moving and identity-changing blocks use these narrower helpers
    // instead so secretary can act on neither, while president/manager (and
    // finance, for the money helper) still can.
    function isPartner()     { return getRole() == 'partner'; }
    function isSeniorAdmin() { return getRole() in ['president', 'manager']; }
    function isMoneyAdmin()  { return getRole() in ['president', 'manager', 'finance']; }

    // Member of the Finance DEPARTMENT (by string `department` or array `departments`),
    // regardless of their role. Lets a Finance-dept staffer record sales income even if
    // their role isn't the special 'finance' role.
    function isFinanceDept() {
      let u = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return u.get('department', '') == 'Finance' || u.get('departments', []).hasAny(['Finance']);
    }
    // Anyone allowed to operate the books: money-tier role OR Finance-dept member.
    // v12 WS19: was isFinanceOrAdmin()||isFinanceDept() — narrowed to isMoneyAdmin()
    // so 'secretary' no longer has ledger/journal write access via this helper.
    function canFinance() { return isMoneyAdmin() || isFinanceDept(); }

    // Member of the Design DEPARTMENT (by string `department` or array `departments`).
    // Same null-safe pattern as isFinanceDept(). Gates Design drawings + project edits.
    function isDesignDept() {
      let u = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return u.get('department', '') == 'Design' || u.get('departments', []).hasAny(['Design']);
    }
    // Anyone allowed to manage Design work: admin role OR Design-dept member.
    function canDesign() { return isAdmin() || isDesignDept(); }

    // Member of the Purchasing DEPARTMENT (by string `department` or array `departments`).
    function isPurchasingDept() {
      let u = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return u.get('department', '') == 'Purchasing' || u.get('departments', []).hasAny(['Purchasing']);
    }
    // Anyone allowed to manage Purchasing work: admin role OR Purchasing-dept member.
    function canPurchasing() { return isAdmin() || isPurchasingDept(); }

    // Member of the Production DEPARTMENT (by string `department` or array `departments`).
    function isProductionDept() {
      let u = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return u.get('department', '') == 'Production' || u.get('departments', []).hasAny(['Production']);
    }
    function canProduction() { return isAdmin() || isProductionDept(); }

    // Generic department membership (null-safe), and "admin OR member of dept D".
    // Used by the per-department document collections (work plans, marketing plans,
    // gov bidding buckets, IT assets/software, etc.).
    function inDept(d) {
      let u = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return u.get('department', '') == d || u.get('departments', []).hasAny([d]);
    }
    function canDept(d) { return isAdmin() || inDept(d); }

    // True when a user-profile update leaves all privileged fields untouched.
    // Used so a non-admin can edit their own name/photo/phone but NOT promote
    // themselves (role) or change their own pay/department/employee ID.
    // NOTE: use .get(field, null) — directly reading a field that is absent on
    // the document raises an error (which DENIES the rule). Worker/partner/older
    // profiles legitimately lack some of these fields, so a direct read broke
    // their routine self-updates (e.g. the lastSeen presence heartbeat). With
    // .get(), an absent field compares null==null and is correctly "unchanged".
    function userPrivilegedFieldsUnchanged() {
      let n = request.resource.data;
      let o = resource.data;
      return n.get('role', null)        == o.get('role', null)
          && n.get('salary', null)      == o.get('salary', null)
          && n.get('allowance', null)   == o.get('allowance', null)
          && n.get('deductions', null)  == o.get('deductions', null)
          && n.get('department', null)  == o.get('department', null)
          && n.get('departments', null) == o.get('departments', null)
          && n.get('employeeId', null)  == o.get('employeeId', null)
          // v12 WS19: username is also privileged — it's the lookup key in the
          // new usernames/{u} map (login), so a free self-change would desync it.
          && n.get('username', null)    == o.get('username', null);
    }

    // ── Users ──────────────────────────────────────────
    match /users/{uid} {
      allow read: if isAuth();
      // Self-signup creates its own doc as 'employee'; admins create staff/worker docs.
      // v12 WS19: only isSeniorAdmin() (president/manager) may mint a manager/
      // president/secretary account — a secretary/other isAdmin() account may
      // still onboard ordinary staff (employee/agent/finance-department hires).
      allow create: if isAuth() && (
        isSeniorAdmin() || (
          isAdmin() && request.resource.data.get('role', 'employee') in ['employee', 'agent', 'finance']
        ) || (
          isOwner(uid)
          && request.resource.data.role == 'employee'
          // Self-signup must not self-assign into a privileged department:
          // Finance/Design membership grants dept-scoped write access via
          // isFinanceDept()/isDesignDept() (and Storage claims via syncUserClaims).
          && request.resource.data.get('department', '') != 'Finance'
          && request.resource.data.get('department', '') != 'Design'
          && !request.resource.data.get('departments', []).hasAny(['Finance','Design'])
        )
      );
      // Owner-first short-circuit: routine self-updates (name/photo/phone/lastSeen)
      // need no role lookup. Privileged fields (role/dept/pay/employeeId/username)
      // are frozen unless a SENIOR admin makes the change — v12 WS19 closes a live
      // self-escalation gap where any isAdmin() (incl. secretary) could write
      // role:'president' onto any user doc with zero field restriction. Secretary/
      // other non-senior admins may still edit a user's non-privileged fields
      // (name/photo/phone) for HR-adjacent oversight, just not the privileged ones.
      allow update: if isAuth() && (
        isSeniorAdmin() ||
        (isOwner(uid) && userPrivilegedFieldsUnchanged()) ||
        (isAdmin() && userPrivilegedFieldsUnchanged())
      );
      allow delete: if isAuth() && isPresident();
    }

    // ── Username → email lookup (v12 WS19) ─────────────
    // Worker login is by username; the client must resolve a username to an
    // email BEFORE calling signInWithEmailAndPassword — i.e. while
    // request.auth is still null. /users read requires isAuth(), so that
    // pre-auth query was always denied (worker username login was broken).
    // Fix: a narrow public single-doc GET (mirrors the order_tracking public-
    // get precedent) — no enumeration (list:false), no other user data exposed.
    match /usernames/{username} {
      allow get: if true;
      allow list: if false;
      allow create, update, delete: if isAuth() && isAdmin();
    }

    // ── Sequence counters (employees, workers, etc.) ────
    // Widened from admin-only to isFinanceOrAdmin() (WS27) so HR/finance can
    // mint BI-W-### worker IDs. Safe: docs here are opaque monotonic integers
    // — the worst a finance user can do is advance a sequence number.
    // Widened again (WS28) so Production can mint DR-serials via nextSerial().
    // Safe per the WS27 rationale: docs here are opaque monotonic integers —
    // the worst any internal user can do is advance a sequence number.
    match /_counters/{docId} {
      allow read:  if isAuth();
      allow write: if isAuth() && !isPartner();
    }

    // ── Posts ──────────────────────────────────────────
    // v12 WS19: read locked to !isPartner() — internal company feed, was bare
    // isAuth() (the audit separately flagged that published-post NOTIFICATIONS
    // also fan out to partners; that's a different, notification-side fix).
    match /posts/{postId} {
      allow read: if isAuth() && !isPartner();
      // v13 Phase 22: enforce the publish/approval model server-side — matches
      // modules.js openNewPostModal (authorId is the real field name; only the
      // president gets publishDirectly, everyone else always lands 'pending').
      allow create: if isAuth() && !isPartner() &&
        request.resource.data.get('authorId', '') == request.auth.uid &&
        request.resource.data.keys().hasOnly([
          'title','content','dept','status','authorId','authorName','authorPhoto',
          'pinned','imageUrl','fileName','fileUrl','createdAt'
        ]) &&
        (isPresident()
          ? request.resource.data.get('status', '') in ['published', 'pending']
          : request.resource.data.get('status', '') == 'pending');
      // Author/admin may edit anything, EXCEPT the publish/reject status
      // transition — decision D10 (modules.js:45 canApprove is president/manager
      // only, secretary does NOT approve posts) is now mirrored server-side via
      // isSeniorAdmin() instead of isAdmin() whenever `status` is in the diff.
      // Anyone may toggle their OWN heart — scoped like the chat reactions
      // pattern (~line 396) so a caller can only add/remove their own uid.
      allow update: if isAuth() && (
        resource.data.authorId == request.auth.uid
        || (isSeniorAdmin() && request.resource.data.diff(resource.data).affectedKeys().hasAny(['status']))
        || (isAdmin() && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['status']))
        || ( request.resource.data.diff(resource.data).affectedKeys().hasOnly(['hearts'])
             && request.resource.data.get('hearts', []).removeAll(resource.data.get('hearts', [])).hasOnly([request.auth.uid])
             && resource.data.get('hearts', []).removeAll(request.resource.data.get('hearts', [])).hasOnly([request.auth.uid]) )
      );
      allow delete: if isAuth() && (resource.data.authorId == request.auth.uid || isAdmin());
    }

    // ── Notifications — anyone signed in can deliver a notification
    // into another user's inbox (Notifs.send/sendToDept/sendToAll/sendToOwner
    // all write cross-user by design); only the inbox owner can read it or
    // mark it read/unread.
    match /notifications/{uid}/{document=**} {
      allow read, update, delete: if isAuth() && isOwner(uid);
      // Cross-user create stays open (broadcast helpers deliver into other inboxes
      // by design), but the payload is constrained so an inbox can't be used to
      // forge arbitrary docs or spam giant push notifications:
      //  • only the fields the app actually writes (Notifs.send/sendTo*),
      //  • must start UNREAD with a server timestamp (no backdating / pre-read),
      //  • title/body length-capped so a sender can't blast oversized pushes.
      allow create: if isAuth()
        && request.resource.data.keys().hasOnly(['title','body','icon','type','link','read','createdAt','dedupKey','taskId','chatId'])
        && request.resource.data.read == false
        && request.resource.data.createdAt == request.time
        && request.resource.data.get('title', '') is string
        && request.resource.data.get('title', '').size() <= 200
        && request.resource.data.get('body', '') is string
        && request.resource.data.get('body', '').size() <= 2000;
    }

    // ── Attendance ─────────────────────────────────────
    // v12 WS19: split from a single `{document=**}` wildcard (plain isOwner(uid),
    // no field constraints at all) into a per-doc records/{date} block, because
    // the client itself writes attendanceScore directly with no server
    // validation — an employee could set attendanceScore:1.0 for any date via
    // devtools, and payroll/EOM read that score directly. `records` is the only
    // subcollection under attendance/{uid} today (verified).
    match /attendance/{uid} {
      allow read: if isAuth() && (isOwner(uid) || isFinanceOrAdmin());
    }
    match /attendance/{uid}/records/{date} {
      allow read: if isAuth() && (isOwner(uid) || isFinanceOrAdmin());
      // Admins: unrestricted (the Present/Half/Absent edit path, stamps editedBy).
      allow write: if isAuth() && isFinanceOrAdmin();
      // Owner self check-in / notification-driven auto-upgrade: score capped to
      // the set an honest client ever produces, and can never overwrite a doc an
      // admin has already hand-edited (protects a Present/Half/Absent correction
      // from being silently reverted by the owner's own next check-in write).
      // A full server-side date-bound (today/yesterday only) would need a Cloud
      // Function — request.time has no clean date-string formatter in rules —
      // deferred; these two checks already close the two exploitable vectors
      // (arbitrary score, overwriting an admin edit). Client call sites need no
      // change — they already write scores in {0.5,1.0} and the admin path
      // already stamps editedBy.
      allow create, update: if isAuth() && isOwner(uid)
        && request.resource.data.get('attendanceScore', 0) in [0, 0.5, 1.0]
        && (resource == null || resource.data.get('editedBy', null) == null);
    }

    // ── Worker kiosk attendance (WS26) ──────────────────
    // Factory worker_profiles staff have no Firebase Auth yet, so there is no
    // owner clause — every record is HR-kiosk-written. When WS27/WS20's
    // worker_profiles.linkedUid lands, an additive owner-read clause can be
    // added here without re-keying (workerId already == the worker_profiles docId).
    match /attendance_worker/{workerId} {
      allow read: if isAuth() && isFinanceOrAdmin();
    }
    match /attendance_worker/{workerId}/records/{date} {
      allow read, write: if isAuth() && isFinanceOrAdmin();
    }

    // ── Attendance extension requests ──────────────────
    match /attendance_extensions/{docId} {
      // Internal HR data — external Brilliant Steel partners excluded from reading.
      // getRole() is null-safe: null (no/missing role) is treated as "not partner"
      // so internal users with incomplete profiles are never wrongly locked out;
      // only a positively-identified 'partner' is denied.
      allow read: if isAuth() && !isPartner();
      allow create: if isAuth();
      allow update, delete: if isAuth() && isAdmin();
    }

    // ── Cash advances ──────────────────────────────────
    match /cash_advances/{docId} {
      allow read: if isAuth() && (
        resource.data.userId == request.auth.uid || isFinanceOrAdmin()
      );
      // Employees may only file their OWN request, pending and unfunded.
      // Money-tier (president/manager/finance) may record/approve any (e.g.
      // president-entered advances) — v12 WS19: narrowed from isFinanceOrAdmin()
      // to isMoneyAdmin() so 'secretary' can no longer approve a cash advance via
      // a direct write (the UI already hides this button from secretary; the
      // rule now matches).
      allow create: if isAuth() && (
        isMoneyAdmin() ||
        (request.resource.data.userId == request.auth.uid
          && request.resource.data.status == 'pending'
          && request.resource.data.balance == 0)
      );
      // Only money-tier can approve or change the money. Owners may edit
      // non-financial details (e.g. reason) but never status/balance/amount.
      allow update: if isAuth() && (
        isMoneyAdmin() ||
        (resource.data.userId == request.auth.uid
          && request.resource.data.status  == resource.data.status
          && request.resource.data.balance == resource.data.balance
          && request.resource.data.amount  == resource.data.amount)
      );
      allow delete: if isAuth() && isPresident();
    }

    // ── Tasks ──────────────────────────────────────────
    match /tasks/{taskId} {
      // v12 WS19: was bare isAuth() — a partner could browse EVERY internal task
      // across every department. BUT a partner's dashboard has a real, shipped
      // "My Tasks" feature (assignedTo array-contains) + an "All Tasks" link into
      // the same tasks page (js/app.js ~2099, openTaskDetail is shared code) —
      // a blanket !isPartner() lock would blank-screen that. Fix: partner may
      // read only tasks they're assigned to; full read stays for internal staff.
      allow read: if isAuth() && (!isPartner() || request.auth.uid in resource.data.get('assignedTo', []));
      // Admins create any task. Design-dept members may create Design tasks only
      // (so designers can delegate project work) — scoped strictly to department=='Design'.
      allow create: if isAuth() && (
        isAdmin() || (isDesignDept() && request.resource.data.get('department', '') == 'Design')
      );
      // Assignees update their own tasks; admins AND finance manage any task
      // (status, reassignment, follow-up requests). Uses isFinanceOrAdmin() so the
      // client's task controls — which treat finance as an editor — actually land
      // (finance is the books/ops editor: "finance can edit everything").
      allow update: if isAuth() && (
        (request.auth.uid in resource.data.assignedTo) || isFinanceOrAdmin()
      );
      // Admins delete any task; a creator may delete the task they made (the UI
      // already offers it to the creator, so this stops a silent permission fail).
      allow delete: if isAuth() && (isAdmin() || resource.data.get('createdBy', '') == request.auth.uid);

      // In-app "messaging" thread on a task. Rules do NOT inherit to
      // subcollections, so this needs explicit coverage — tasks are readable
      // by all signed-in users, so their messages are too. Author owns their
      // own message; admins can moderate.
      // v12 WS19: same own-task scoping as the parent — a partner assigned to
      // THIS task can still read/use its comment thread (openTaskDetail is
      // shared code with the partner dashboard); a partner NOT assigned cannot.
      function taskAssignee() {
        return request.auth.uid in get(/databases/$(database)/documents/tasks/$(taskId)).data.get('assignedTo', []);
      }
      match /comments/{commentId} {
        allow read:   if isAuth() && (!isPartner() || taskAssignee());
        allow create: if isAuth() && request.resource.data.authorId == request.auth.uid;
        allow update, delete: if isAuth() && (
          resource.data.authorId == request.auth.uid || isAdmin()
        );
      }
      // Read receipts ("Seen by"). Each user writes only their own receipt.
      match /readers/{readerUid} {
        allow read:  if isAuth() && (!isPartner() || taskAssignee());
        allow write: if isAuth() && isOwner(readerUid);
      }
    }

    // ── Team Chat (v12 WS37) — conversations + messages/readers/typing ──
    // One collection, three types: 'dm' | 'group' | 'dept'.
    //  • dm/group: membership = the participants array. A partner may read/write
    //    ONLY conversations they're a participant of (conditional wall, same
    //    semantics as tasks/comments) — and unlike tasks, internal staff are
    //    participant-scoped too (nobody reads a DM they're not in).
    //  • dept: membership derived live via isAdmin() || inDept(department);
    //    partners NEVER pass this branch. participants stays [] on dept docs.
    // Rules do NOT cascade — messages/readers/typing each get an explicit match.
    match /conversations/{convId} {
      // Membership vs THIS doc (parent reads/updates — no extra get()).
      function memberOfDoc() {
        return (request.auth.uid in resource.data.get('participants', []))
          || (resource.data.get('type','') == 'dept' && !isPartner()
              && (isAdmin() || inDept(resource.data.get('department',''))));
      }
      // Membership via re-read, for subcollections (mirrors taskAssignee()).
      function convMember() {
        let c = get(/databases/$(database)/documents/conversations/$(convId)).data;
        return (request.auth.uid in c.get('participants', []))
          || (c.get('type','') == 'dept' && !isPartner()
              && (isAdmin() || inDept(c.get('department',''))));
      }

      // get: any member. list: the inbox query is participants array-contains,
      // provable from the first disjunct; dept docs are fetched by direct get.
      allow read: if isAuth() && memberOfDoc();

      // dm/group: creator must include themself. dept: lazy-create by any member;
      // the doc ID must be exactly 'dept_<department>' and participants must be [].
      allow create: if isAuth() && (
        ( request.resource.data.get('type','') in ['dm','group']
          && request.resource.data.get('createdBy','') == request.auth.uid
          && request.auth.uid in request.resource.data.get('participants', []) )
        ||
        ( request.resource.data.get('type','') == 'dept' && !isPartner()
          && (isAdmin() || inDept(request.resource.data.get('department','')))
          && convId == 'dept_' + request.resource.data.get('department','')
          && request.resource.data.get('participants', []).size() == 0 )
      );

      // Any member may bump ONLY the lastMessage* preview fields (the second
      // write of every send). Creator/admin manage the doc (rename, members).
      // A participant may remove exactly themself ("leave group").
      allow update: if isAuth() && (
        ( memberOfDoc() && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['lastMessageAt','lastMessageText','lastMessageBy','lastMessageByName']) )
        || resource.data.get('createdBy','') == request.auth.uid
        || isAdmin()
        || ( request.resource.data.diff(resource.data).affectedKeys().hasOnly(['participants'])
             && request.resource.data.get('participants', [])
                == resource.data.get('participants', []).removeAll([request.auth.uid]) )
      );

      allow delete: if isAuth() && isPresident();   // records kept forever

      match /messages/{messageId} {
        allow read:   if isAuth() && convMember();
        allow create: if isAuth() && convMember()
          && request.resource.data.get('authorId','') == request.auth.uid;
        // Author edits own message; admin moderates; any member may toggle
        // their OWN key inside the reactions map — and nothing else.
        allow update: if isAuth() && (
          resource.data.get('authorId','') == request.auth.uid
          || isAdmin()
          || ( convMember()
               && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions'])
               && request.resource.data.get('reactions', {})
                    .diff(resource.data.get('reactions', {})).affectedKeys()
                    .hasOnly([request.auth.uid]) )
        );
        allow delete: if isAuth()
          && (resource.data.get('authorId','') == request.auth.uid || isAdmin());
      }
      // Read receipts — per-viewer-writes-own-doc, verbatim tasks/readers shape
      // (+ convMember so a non-participant can't plant a receipt).
      match /readers/{readerUid} {
        allow read:  if isAuth() && convMember();
        allow write: if isAuth() && isOwner(readerUid) && convMember();
      }
      // Typing beacons — own doc only (write covers create/update/delete).
      match /typing/{typerUid} {
        allow read:  if isAuth() && convMember();
        allow write: if isAuth() && isOwner(typerUid) && convMember();
      }
    }

    // ── KPI evaluations ────────────────────────────────
    match /kpi_evals/{uid} {
      // The president's grade lives in the SAME doc as the employee's self-
      // assessment. The owner may write their self-assessment but must NOT be able
      // to forge/inflate the president's grade — freeze the president-* fields for
      // non-admins. Only finance/admin (and the president) may write them.
      function presFieldsUntouchedOnUpdate() {
        return !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(['presidentGrade','presidentNotes','presidentImprovements','presidentUpdatedAt','presidentGradeFromTasks','presidentScoreTaskCount']);
      }
      function presFieldsAbsentOnCreate() {
        return !request.resource.data.keys()
          .hasAny(['presidentGrade','presidentNotes','presidentImprovements','presidentUpdatedAt','presidentGradeFromTasks','presidentScoreTaskCount']);
      }
      // v12 WS19: create/update's admin branch narrowed to isSeniorAdmin() — the
      // isOwner branch is frozen by presFieldsAbsentOnCreate/UntouchedOnUpdate,
      // but the admin branch had NO such freeze, so 'secretary' could otherwise
      // write/forge presidentGrade directly. Only president/manager grade KPIs.
      allow read:   if isAuth() && (isOwner(uid) || isFinanceOrAdmin());
      allow create: if isAuth() && (isSeniorAdmin() || (isOwner(uid) && presFieldsAbsentOnCreate()));
      allow update: if isAuth() && (isSeniorAdmin() || (isOwner(uid) && presFieldsUntouchedOnUpdate()));
      allow delete: if isAuth() && isFinanceOrAdmin();
    }

    // ── KPI targets ────────────────────────────────────
    match /kpi_targets/{uid} {
      allow read: if isAuth() && (isOwner(uid) || isAdmin());
      allow write: if isAuth() && isAdmin();
    }

    // ── Settings ───────────────────────────────────────
    // v12 WS19: read locked to internal staff on the internal docs (sales_sop,
    // employeeOfMonth) — was bare isAuth(). 'system' stays universally readable:
    // EVERY session (incl. partner) listens to settings/system via onSnapshot
    // for the president's force-logout signal (js/app.js:135) — locking it out
    // would silently break force-logout for partner sessions specifically,
    // exactly when the President most needs it to work (cutting off a
    // compromised/terminated partner account).
    match /settings/{docId} {
      allow read: if isAuth() && (!isPartner() || docId == 'system');
      allow write: if isAuth() && isPresident();
    }

    // ── Holidays admin overrides (WS26) ─────────────────
    // Dedicated collection so the looser finance/admin write does NOT touch
    // the president-only settings/{docId} match above (which also gates
    // employeeOfMonth/sales_sop — loosening it would loosen those too).
    match /settings_holidays/{year} {
      allow read:  if isAuth();
      allow write: if isAuth() && isFinanceOrAdmin();
    }

    // ── Strategy / market-research notes (v12 WS40) ──────────────────
    // docId ∈ {general,sales,marketing,production,finance,gov}. Read scoped to the
    // Analytics tier (president/manager/secretary/finance); entries appended via
    // arrayUnion. Secretary is view-only CLIENT-side (WS25 decision-9 pattern) —
    // rules keep the tier uniform. .get() defaults per missing-field-throws memory.
    match /strategy_notes/{deptKey} {
      allow read:  if isAuth() && isFinanceOrAdmin();
      allow write: if isAuth() && isFinanceOrAdmin()
        && request.resource.data.get('entries', []) is list;
      allow delete: if isAuth() && isPresident();
    }

    // ── System health (backup/sync heartbeat) ──────────
    // Written ONLY by the GitHub Actions backup/sync jobs via the Admin SDK
    // (which bypasses these rules). No client ever writes it.
    match /system_health/{jobId} {
      allow read:  if isAuth() && isFinanceOrAdmin();
      allow write: if false;
    }

    // ── President message ──────────────────────────────
    match /president_message/{docId} {
      allow read: if isAuth() && !isPartner();
      allow write: if isAuth() && isPresident();
    }

    // ── SOPs — readable by internal staff, editable by admins ────────────
    // v12 WS19: read locked to !isPartner() — was bare isAuth(). Write stays
    // isAdmin() (secretary keeps this oversight/coordination surface).
    match /sops/{docId} {
      allow read: if isAuth() && !isPartner();
      allow write: if isAuth() && isAdmin();
    }

    // ── Payroll (live pay: salary/allowance/deductions) ─
    // Moved off the world-readable users doc so pay isn't visible to all staff.
    // Each user may read their OWN pay; only finance/admin may read others or write.
    // v12 WS19: create/update narrowed isFinanceOrAdmin() -> isMoneyAdmin() on
    // payroll/salary_history/salary_raises/payroll_ca_overrides (secretary no
    // longer writes live pay); read stays isFinanceOrAdmin() (secretary keeps
    // oversight visibility) — only the write surface is money-tier now.
    match /payroll/{uid} {
      allow read:  if isAuth() && (isOwner(uid) || isFinanceOrAdmin());
      allow create, update: if isAuth() && isMoneyAdmin();
      allow delete: if isAuth() && isPresident();
    }

    // ── Salary history ─────────────────────────────────
    match /salary_history/{docId} {
      allow read: if isAuth() && (
        resource.data.userId == request.auth.uid || isFinanceOrAdmin()
      );
      allow create, update: if isAuth() && isMoneyAdmin();
      allow delete: if isAuth() && isPresident();
    }

    // ── Salary raises (audit log of pay increases) ─────
    // Finance/admin grant & manage; the affected app-user may read their own.
    match /salary_raises/{docId} {
      allow read: if isAuth() && (
        resource.data.subjectId == request.auth.uid || isFinanceOrAdmin()
      );
      allow create, update: if isAuth() && isMoneyAdmin();
      allow delete: if isAuth() && isPresident();
    }

    // ── Pending / scheduled raises (v12 WS23 — approval-routed schedule) ────
    // Non-president finance may only FILE a request (status pending_approval —
    // filing is a safe escalation, not itself money-moving, matching the
    // secretary's existing "request President approval" pattern elsewhere).
    // President approves → scheduled; the screen-load sweep materializes
    // (scheduled → applied). Subject may read their own.
    match /pending_raises/{docId} {
      allow read: if isAuth() && (
        resource.data.subjectId == request.auth.uid || isFinanceOrAdmin()
      );
      allow create: if isAuth() && (
        isPresident()
        || ( isFinanceOrAdmin()
             && request.resource.data.get('status','') == 'pending_approval' )
      );
      allow update: if isAuth() && (
        // Automated materialize: any finance, ONLY scheduled → applied.
        ( isFinanceOrAdmin()
          && resource.data.get('status','') == 'scheduled'
          && request.resource.data.get('status','') == 'applied' )
        // Approve / reject / cancel / reschedule: President only.
        || isPresident()
      );
      allow delete: if isAuth() && isPresident();
    }

    // ── Payroll CA overrides ───────────────────────────
    match /payroll_ca_overrides/{docId} {
      allow read: if isAuth() && (
        resource.data.userId == request.auth.uid || isFinanceOrAdmin()
      );
      allow write: if isAuth() && isMoneyAdmin();
    }

    // ── Payroll delete requests ────────────────────────
    match /payroll_delete_requests/{docId} {
      allow read: if isAuth() && isFinanceOrAdmin();
      allow create: if isAuth() && isFinanceOrAdmin();
      allow update, delete: if isAuth() && isPresident();
    }

    // ── Pay runs (Compute → Verify → Disburse workflow state per month) ──
    // Doc id = YYYY-MM. Governance metadata only (no raw pay). Finance/admin
    // read & write; the President prunes.
    // v12 WS20 — transition-aware state machine. isMoneyAdmin() (not
    // isFinanceOrAdmin()) drives Compute/Verify so 'secretary' can't write
    // pay_runs directly (matches WS19's money-tier narrowing everywhere else).
    // 'disbursed' is reachable ONLY by the president, ONLY from 'verified', and
    // is immutable afterward — no clause below permits updating a disbursed doc.
    match /pay_runs/{month} {
      allow read: if isAuth() && isFinanceOrAdmin();
      allow create: if isAuth() && isMoneyAdmin() &&
        request.resource.data.get('state','draft') in ['draft','computed'];
      allow update: if isAuth() && (
        ( isMoneyAdmin() &&
          resource.data.get('state','draft') in ['draft','computed'] &&
          request.resource.data.get('state','') in ['computed','verified'] )
        ||
        ( isPresident() && (
            // verify → disbursing (transactional lock acquisition — Part E Phase 11)
            ( resource.data.get('state','')=='verified' &&
              request.resource.data.get('state','')=='disbursing' ) ||
            // disbursing → disbursed (lock release on success)
            ( resource.data.get('state','')=='disbursing' &&
              request.resource.data.get('state','')=='disbursed' ) ||
            // president reopen: verified → computed
            ( resource.data.get('state','')=='verified' &&
              request.resource.data.get('state','')=='computed' ) ||
            // president manual unlock after investigating a stuck/partial
            // disburse: disbursing → computed (Part E Phase 11)
            ( resource.data.get('state','')=='disbursing' &&
              request.resource.data.get('state','')=='computed' ) ||
            // president may also perform the finance-tier transitions
            ( resource.data.get('state','draft') in ['draft','computed'] &&
              request.resource.data.get('state','') in ['computed','verified'] )
        ))
      );
      allow delete: if isAuth() && isPresident();
    }

    // ── Expenses ───────────────────────────────────────
    match /expenses/{docId} {
      allow read: if isAuth() && (
        resource.data.createdBy == request.auth.uid || isFinanceOrAdmin()
      );
      allow create: if isAuth() && request.resource.data.createdBy == request.auth.uid;
      // Owners may edit their own expense details but not approve it (status frozen).
      allow update: if isAuth() && (
        isFinanceOrAdmin() ||
        (resource.data.createdBy == request.auth.uid
          && request.resource.data.status == resource.data.status)
      );
      // Delete is President-only — finance staff request it via the approval flow.
      allow delete: if isAuth() && isPresident();
    }

    // ── Submissions ────────────────────────────────────
    match /submissions/{docId} {
      allow read: if isAuth() && (
        resource.data.createdBy == request.auth.uid || isAdmin()
      );
      allow create: if isAuth() && request.resource.data.createdBy == request.auth.uid;
      allow update: if isAuth() && isAdmin();
      allow delete: if isAuth() && isAdmin();

      // Submission message thread mirrors the parent's access (submitter ↔ admin).
      // Rules don't inherit to subcollections, so we re-check the parent here.
      match /comments/{commentId} {
        function parentSub() {
          return get(/databases/$(database)/documents/submissions/$(docId)).data;
        }
        allow read: if isAuth() && (
          parentSub().get('createdBy','') == request.auth.uid || isAdmin()
        );
        allow create: if isAuth()
          && request.resource.data.authorId == request.auth.uid
          && (parentSub().get('createdBy','') == request.auth.uid || isAdmin());
        allow update, delete: if isAuth() && (
          resource.data.authorId == request.auth.uid || isAdmin()
        );
      }
    }

    // ── Quotes (internal) ──────────────────────────────
    // NOTE: was incorrectly named 'quotations' in previous rules — fixed
    // v12 WS19: read locked to !isPartner() — this is the INTERNAL Sales quotes
    // collection (distinct from bk_quotes/bs_quotes, which already correctly
    // exclude/scope the partner) and was bare isAuth().
    match /quotes/{docId} {
      allow read: if isAuth() && !isPartner();
      allow write: if isAuth() && isAdmin();
    }

    // ── BS Quotes (Brilliant Steel partner) ────────────
    // One-way visibility: partner quotes ARE visible to internal staff (Sales,
    // etc.) so they can coordinate; a partner only ever sees their OWN quotes.
    // (The reverse — partner reading internal bk_quotes — is denied below.)
    match /bs_quotes/{docId} {
      allow read: if isAuth() && (
        resource.data.createdBy == request.auth.uid || !isPartner()
      );
      allow create: if isAuth() && request.resource.data.createdBy == request.auth.uid;
      allow update: if isAuth() && (
        resource.data.createdBy == request.auth.uid || isAdmin()
      );
      allow delete: if isAuth() && isAdmin();
    }

    // ── BK Quotes (Barro Kitchens / internal Sales) ────
    // Internal sales quotes are NOT visible to external partners — only the
    // creator or an admin may read. A partner has no bk_quotes of their own,
    // so this collection is effectively invisible to them.
    match /bk_quotes/{docId} {
      allow read: if isAuth() && !isPartner() && (
        resource.data.createdBy == request.auth.uid || isAdmin()
      );
      // Admins may also create with a DIFFERENT createdBy: required by the v12
      // WS31 stranded-quote migration, which moves misfiled BK docs out of
      // bs_quotes preserving the ORIGINAL creator for the audit trail. Partner
      // isolation is unchanged (partners still can never touch bk_quotes at all).
      allow create: if isAuth() && !isPartner() &&
        (request.resource.data.createdBy == request.auth.uid || isAdmin());
      allow update: if isAuth() && !isPartner() && (
        resource.data.createdBy == request.auth.uid || isAdmin()
      );
      allow delete: if isAuth() && isAdmin();
    }

    // ── Approval requests ──────────────────────────────
    match /approval_requests/{docId} {
      // Internal workflow data — external partners excluded from reading.
      allow read: if isAuth() && !isPartner();
      // v13 Phase 21: the ONLY two client write sites into this collection are
      // app.js's CA-deduction override modal (type 'ca_deduct', ownership via
      // userId) and the BS-quote review flow (type 'bs_quote', ownership via
      // agentId — that path has no userId field). Everything else that shows
      // up in the "All Requests" dashboard (signup/attendance/submission/
      // review-task/leave) lives in its own separate collection, not here —
      // do not widen this list without a matching new .add() call site.
      allow create: if isAuth() &&
        (request.resource.data.get('userId', '') == request.auth.uid ||
         request.resource.data.get('agentId', '') == request.auth.uid ||
         isFinanceOrAdmin()) &&
        request.resource.data.get('status', '') == 'pending' &&
        request.resource.data.get('type', '') in ['ca_deduct', 'bs_quote'] &&
        request.resource.data.keys().hasOnly([
          'type','status','createdAt','userId','userName','month','amount','reason',
          'quoteId','quoteColl','quoteNumber','clientName','total','agentName','agentId'
        ]) &&
        (request.resource.data.get('amount', 0) is number && request.resource.data.get('amount', 0) >= 0);
      // v12 WS19: the client's APPROVAL_CAPS table already hides money/quote
      // approve-buttons from secretary, but the rule itself allowed any isAdmin()
      // to approve them via a direct write — tightened to match: secretary
      // (isAdmin() but not isSeniorAdmin()) may only act on the MINOR request
      // types; money/quote/finance approvals need president or manager.
      allow update: if isAuth() && (
        isSeniorAdmin() ||
        (isAdmin() && resource.data.get('type', '') in
          ['signup', 'attendance', 'submission', 'review-task', 'leave', 'ca_deduct'])
      );
      allow delete: if isAuth() && isAdmin();
    }

    // ── Signup requests — anyone can apply (pre-auth) ──
    match /signup_requests/{docId} {
      // Public but constrained to the exact application shape, so this open
      // endpoint can't be abused to write arbitrary or oversized documents.
      allow create: if request.resource.data.keys().hasOnly(['fullName','email','phone','status','createdAt'])
        && request.resource.data.status == 'pending'
        && request.resource.data.fullName is string && request.resource.data.fullName.size() <= 120
        && request.resource.data.email    is string && request.resource.data.email.size() <= 200
        && request.resource.data.phone    is string && request.resource.data.phone.size() <= 40;
      allow read, update, delete: if isAuth() && isAdmin();
    }

    // ── Partner deals (50/50 profit split) ────────────
    match /partner_deals/{docId} {
      // Partners can read their own deals; admins can read all.
      allow read: if isAuth() && (
        resource.data.partnerUid == request.auth.uid || isAdmin()
      );
      // Only money-tier can create/update deals (this is a profit-split payout
      // record) — partners cannot self-register earnings. v12 WS19: narrowed
      // from isAdmin() to isMoneyAdmin() so secretary can't post a deal.
      allow create, update: if isAuth() && isMoneyAdmin();
      allow delete: if isAuth() && isPresident();
    }

    // ── Products catalog ───────────────────────────────
    match /products/{docId} {
      allow read: if isAuth();
      allow write: if isAuth() && isAdmin();
    }
    match /productMeta/{docId} {
      allow read: if isAuth();
      allow write: if isAuth() && isAdmin();
    }

    // ── Reference materials ────────────────────────────
    // v12 WS19: read locked to internal staff (!isPartner()) on all four — were
    // bare isAuth(). Write stays isAdmin() (secretary keeps this surface).
    match /resources/{docId} {
      allow read: if isAuth() && !isPartner();
      allow write: if isAuth() && isAdmin();
    }
    match /policies/{docId} {
      allow read: if isAuth() && !isPartner();
      allow write: if isAuth() && isAdmin();
    }
    match /handbook/{docId} {
      allow read: if isAuth() && !isPartner();
      allow write: if isAuth() && isAdmin();
    }
    match /memos/{docId} {
      allow read:   if isAuth() && !isPartner();
      allow create: if isAuth() && isAdmin();
      allow delete: if isAuth() && isAdmin();
      // Admins edit freely. A tagged recipient may update ONLY to record their
      // own conforme, and the entry is locked to a trustworthy, server-stamped,
      // write-once record so it can stand as a real acknowledgment:
      //   • only the `conformes` map may change, and within it only their own uid;
      //   • write-once — an existing conforme can't be re-written by the recipient
      //     (only an admin could correct it);
      //   • the entry must be exactly {at, name} with `at` == the server time
      //     (a client-supplied/back-dated Date won't equal request.time → rejected)
      //     and `name` a bounded string — so the timestamp and shape can't be forged.
      allow update: if isAuth() && (
        isAdmin() || (
          (request.auth.uid in resource.data.get('recipients', []))
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['conformes'])
          && request.resource.data.conformes.diff(resource.data.get('conformes', {}))
               .affectedKeys().hasOnly([request.auth.uid])
          && !(request.auth.uid in resource.data.get('conformes', {}))
          && request.resource.data.conformes[request.auth.uid].keys().hasOnly(['at','name'])
          && request.resource.data.conformes[request.auth.uid].at == request.time
          && request.resource.data.conformes[request.auth.uid].name is string
          && request.resource.data.conformes[request.auth.uid].name.size() <= 200
        )
      );
    }

    // ── Projects ───────────────────────────────────────
    // v12 WS19: read locked to !isPartner() — was bare isAuth(). NOTE: this is
    // DIFFERENT from /job_projects (which already correctly partner-scopes) —
    // the unified Projects view already skips this collection for partners
    // client-side, so this closes the gap without any UI regression.
    match /projects/{docId} {
      allow read: if isAuth() && !isPartner();
      allow create: if isAuth();
      // Creator/admin can edit anything; finance (role or Finance-dept) may also
      // update so they can record payments & issue billing invoices for collection.
      // Design-dept members may edit too (team/drawings-link/status). .get() is
      // null-safe for older docs whose createdBy field is absent.
      allow update: if isAuth() && (
        resource.data.get('createdBy', '') == request.auth.uid || isAdmin() || canFinance() || canDesign()
      );
      allow delete: if isAuth() && isAdmin();
    }

    // ── Design drawings (flat, projectId-scoped; full revision control) ──
    // DWG/PDF/2D/3D drawings attached to a Design project. Top-level collection
    // (not a subcollection) so the cross-project Drawings dashboard is a simple
    // query. Rules do NOT cascade, so this needs its own block. All field reads
    // are .get(field, default) — a bare read of an absent field DENIES the rule.
    // v12 WS19: read locked to !isPartner() — was bare isAuth().
    // v12 WS35: real approval gate. 'approved' and 'released' are privileged
    // transitions with a pinned topology (for_review→approved→released), approvable
    // only by president/manager or the parent project's designLead — and NEVER by
    // the drawing's own author/assignee (self-approval hole closed at the rules
    // layer, not just the UI). secretary is deliberately NOT an approver (view-only
    // approvals directive), which is why this uses an explicit role list instead
    // of isAdmin(). Everything that is not a promotion to approved/released keeps
    // the old gate.
    match /design_drawings/{docId} {
      // President/manager, or the designLead of the drawing's parent project.
      // Role check FIRST so admins never depend on the project get() resolving.
      function isDrawingApprover() {
        return getRole() in ['president', 'manager']
          || request.auth.uid == get(/databases/$(database)/documents/projects/$(resource.data.get('projectId', '_none_'))).data.get('designLead', '');
      }
      function statusNow()  { return resource.data.get('status', ''); }
      function statusNext() { return request.resource.data.get('status', ''); }
      // Promotion = the status field is CHANGING to approved/released.
      function isPromotion() {
        return statusNext() in ['approved', 'released'] && statusNext() != statusNow();
      }
      allow read:   if isAuth() && !isPartner();
      // v12 WS35: new drawings must start at draft (no API-created pre-approved docs).
      allow create: if isAuth() && canDesign()
                    && request.resource.data.get('createdBy', '') == request.auth.uid
                    && request.resource.data.get('status', 'draft') == 'draft';
      allow update: if isAuth() && (
        // (1) ordinary edits + demotions (revisions, back-to-draft/review, supersede,
        //     reactivate, field edits with status unchanged) — the pre-WS35 gate
        ( !isPromotion() && (
             resource.data.get('createdBy', '')  == request.auth.uid
          || resource.data.get('assignedTo', '') == request.auth.uid
          || canDesign()
        ))
        // (2) APPROVE: for_review → approved, by an approver who is not the
        //     drawing's author or assigned designer (two-party control)
        || ( statusNext() == 'approved' && statusNow() == 'for_review'
          && isDrawingApprover()
          && request.auth.uid != resource.data.get('createdBy', '')
          && request.auth.uid != resource.data.get('assignedTo', '') )
        // (3) RELEASE: approved → released, by an approver (independence was
        //     already enforced when 'approved' was reached — see clause 2)
        || ( statusNext() == 'released' && statusNow() == 'approved'
          && isDrawingApprover() )
      );
      allow delete: if isAuth() && isAdmin();
    }

    // ── IT collections ─────────────────────────────────
    // v12 WS19: read locked to !isPartner() on all three — were bare isAuth().
    match /it_tickets/{docId} {
      allow read: if isAuth() && !isPartner();
      allow create: if isAuth();
      allow update: if isAuth() && (
        resource.data.createdBy == request.auth.uid || isAdmin()
      );
      allow delete: if isAuth() && isAdmin();
    }
    // IT assets/software: IT-dept members manage them (UI gates on canEditDept('IT')).
    match /it_assets/{docId} {
      allow read: if isAuth() && !isPartner();
      allow write: if isAuth() && canDept('IT');
    }
    match /it_software/{docId} {
      allow read: if isAuth() && !isPartner();
      allow write: if isAuth() && canDept('IT');
    }
    match /it_access/{docId} {
      allow read: if isAuth() && (isAdmin() || inDept('IT'));
      allow write: if isAuth() && (isAdmin() || inDept('IT'));
    }
    match /it_network/{docId} {
      allow read: if isAuth() && (isAdmin() || inDept('IT'));
      allow write: if isAuth() && (isAdmin() || inDept('IT'));
    }

    // ── Per-department document collections (renderDocCollection) ───────
    // These were unruled → silent permission-denied (blank screens). Internal
    // staff read; the owning department (or an admin) writes. Partners excluded.
    match /work_plans/{docId} {
      allow read: if isAuth() && !isPartner();
      allow write: if isAuth() && canDept('Sales');
    }
    match /marketing_plans/{docId} {
      allow read: if isAuth() && !isPartner();
      allow write: if isAuth() && canDept('Marketing');
    }
    match /marketing_proposals/{docId} {
      allow read: if isAuth() && !isPartner();
      allow write: if isAuth() && canDept('Marketing');
    }

    // ── Marketing suite (v12 WS34): campaigns, promotions calendar, strategy
    // templates. Literal-named root collections (the files_*/budgets_* wildcard
    // deliberately does not apply). Read = internal staff; write = Marketing
    // members or admins (canDept, same pattern as marketing_plans above).
    // .get(field, default) everywhere per the missing-field-throws memory.
    match /campaigns/{docId} {
      allow read: if isAuth() && !isPartner();
      allow create: if isAuth() && canDept('Marketing')
        && request.resource.data.get('name', '') != ''
        && request.resource.data.get('status', 'planned') in ['planned','active','done','cancelled']
        && request.resource.data.get('budget', 0) is number
        && request.resource.data.get('budget', 0) >= 0
        && request.resource.data.get('createdBy', '') == request.auth.uid;
      allow update: if isAuth() && canDept('Marketing')
        && request.resource.data.get('status', 'planned') in ['planned','active','done','cancelled']
        && request.resource.data.get('budget', 0) is number
        && request.resource.data.get('budget', 0) >= 0;
      // Delete is admin-only: clients.campaignId points here — cancel, don't delete.
      allow delete: if isAuth() && isAdmin();
    }
    match /promotions/{docId} {
      allow read: if isAuth() && !isPartner();
      allow create: if isAuth() && canDept('Marketing')
        && request.resource.data.get('title', '') != ''
        && request.resource.data.get('createdBy', '') == request.auth.uid;
      allow update, delete: if isAuth() && canDept('Marketing');
    }
    match /marketing_templates/{docId} {
      allow read: if isAuth() && !isPartner();
      allow write: if isAuth() && canDept('Marketing');
    }

    match /gov_philgeps/{docId} {
      allow read: if isAuth() && !isPartner();
      allow write: if isAuth() && canDept('Government Biddings');
    }
    match /gov_active_bids/{docId} {
      allow read: if isAuth() && !isPartner();
      allow write: if isAuth() && canDept('Government Biddings');
    }
    match /gov_archive/{docId} {
      allow read: if isAuth() && !isPartner();
      allow write: if isAuth() && canDept('Government Biddings');
    }

    // ── AEC Partner Directory (Sales prospecting: architects/engineers/contractors,
    // v12 WS33). Internal pipeline — partner excluded, matching work_plans. Writes
    // follow the TIGHTENED canDept pattern — deliberately stricter than the legacy
    // bare-isAuth() sales_clients block (~1121); that looseness is pre-existing,
    // not the template. Delete admin-only (no delete-request flow: low-stakes list).
    match /aec_contacts/{docId} {
      allow read: if isAuth() && !isPartner();
      allow create, update: if isAuth() && canDept('Sales');
      allow delete: if isAuth() && isAdmin();
    }

    // ── Finance journals & records ─────────────────────
    // Finance may create + edit every line. DELETE is President-only: finance
    // staff file a finance_delete_requests doc that the President approves in the
    // Approvals tab (the actual delete then runs in the President's context). This
    // mirrors the existing salary_history / cash_advances delete gate.
    // v12 WS12 — period-close guard helpers. A ledger create must (a) carry a
    // real date (every one of the ~14 client posting sites already sends one —
    // this only catches a malformed/missing date before it can silently vanish
    // from an orderBy('date') report) and (b) target a month that isn't closed.
    // Missing finance_periods doc = open (fail-open on absence, the safe default
    // per the missing-field-denies gotcha). President bypasses the close-lock —
    // the governance model is reopen -> fix -> re-close, never a silent side door.
    function ledgerDateOk() {
      return request.resource.data.get('date', '').matches('^\\d{4}-\\d{2}(-\\d{2})?$');
    }
    function ledgerPeriodOpen() {
      return isPresident() ||
        !exists(/databases/$(database)/documents/finance_periods/$(
          request.resource.data.get('date', '').split('-')[0] + '-' +
          request.resource.data.get('date', '').split('-')[1])) ||
        get(/databases/$(database)/documents/finance_periods/$(
          request.resource.data.get('date', '').split('-')[0] + '-' +
          request.resource.data.get('date', '').split('-')[1])).data.get('closed', false) == false;
    }
    match /finance_periods/{month} {
      allow read: if isAuth() && canFinance();
      allow create, update: if isAuth() && isPresident();
      allow delete: if false;
    }
    match /ledger/{docId} {
      allow read: if isAuth() && canFinance();
      // Finance/admin post anything (subject to the date + period-close gate
      // above). Production may ALSO post its own material COS — v12 WS13 adds a
      // second Production-postable shape, the Inventory contra-leg that nets the
      // consumption expense against the asset booked at purchase time (fixes
      // double material expensing). Both legs are tightly fenced: fixed
      // category/source/type/refNumber pattern, positive amount only — so a
      // Production user can't forge revenue, a negative, or an arbitrary entry.
      // accountType is read tolerantly (.get(...,'expense')/.get(...,'')) so an
      // old, not-yet-updated client posting the legacy (no-accountType) COS shape
      // is still accepted. Update/delete stay finance/president.
      // v12 WS36 — bankFlow shape guard ('' | 'in' | 'out'). .get(field,default) so
      // untagged rows and old clients (no bankFlow at all) still pass.
      allow create: if isAuth() && ledgerDateOk() && ledgerPeriodOpen()
        && request.resource.data.get('bankFlow', '') in ['', 'in', 'out'] && (
        canFinance()
        || (canProduction()
            && request.resource.data.get('source', '') == 'Production'
            && request.resource.data.get('amount', 0) is number
            && request.resource.data.get('amount', 0) > 0
            && (
              // expense leg (COS – Direct Material) — old clients (no accountType
              // field) and new clients (accountType:'expense') both accepted.
              (request.resource.data.get('type', '') == 'debit'
                && request.resource.data.get('category', '') == 'COS – Direct Material'
                && request.resource.data.get('refNumber', '').matches('POCOS-.*')
                && request.resource.data.get('accountType', 'expense') == 'expense')
              ||
              // Inventory contra leg — new clients only.
              (request.resource.data.get('type', '') == 'credit'
                && request.resource.data.get('accountType', '') == 'asset'
                && request.resource.data.get('account', '') == 'Inventory'
                && request.resource.data.get('refNumber', '').matches('POCOS-.*-INV'))
            ))
      );
      allow update: if isAuth() && canFinance()
        && request.resource.data.get('bankFlow', '') in ['', 'in', 'out'];
      allow delete: if isAuth() && isPresident();
    }
    match /ledger_entries/{docId} {
      allow read: if isAuth() && canFinance();
      allow create, update: if isAuth() && canFinance();
      allow delete: if isAuth() && isPresident();
    }
    match /cash_receipt_journal/{docId} {
      allow read: if isAuth() && canFinance();
      allow create, update: if isAuth() && canFinance();
      allow delete: if isAuth() && isPresident();
    }
    match /cash_disbursement_journal/{docId} {
      allow read: if isAuth() && canFinance();
      allow create, update: if isAuth() && canFinance();
      allow delete: if isAuth() && isPresident();
    }
    match /general_journal/{docId} {
      allow read: if isAuth() && canFinance();
      allow create, update: if isAuth() && canFinance();
      allow delete: if isAuth() && isPresident();
    }
    match /finance_records/{docId} {
      allow read: if isAuth() && canFinance();
      allow create, update: if isAuth() && canFinance();
      allow delete: if isAuth() && isPresident();
    }
    match /tax_records/{docId} {
      allow read: if isAuth() && canFinance();
      allow create, update: if isAuth() && canFinance();
      allow delete: if isAuth() && isPresident();
    }
    // Purchase requisitions — the Purchasing department's RFQ → Purchase Request
    // flow (stage: 'rfq' | 'pr'). Purchasing dept maintains them; Finance gets
    // read access to see committed purchases. Draft RFQs are freely deletable by
    // Purchasing; once converted to a PR, only the President may delete.
    // v12 WS30 — PO approval gate: converting sets approvalStatus:'pending';
    // ONLY president/manager may set 'approved'/'rejected'; Purchasing can never
    // self-approve, and can't mark a PO ordered/received until it is approved.
    // Docs converted BEFORE the gate have no approvalStatus at all and are
    // grandfathered — .get(field,'legacy') per the missing-field-throws memory.
    match /purchase_requisitions/{docId} {
      allow read: if isAuth() && (canPurchasing() || canFinance());
      allow create: if isAuth() && canPurchasing();
      allow update: if isAuth() && (
        // (a) Purchasing edits freely EXCEPT the approval verdict: approval
        //     fields are writable here only when the result is 'pending'
        //     (convert / re-convert) or cleared by a revert back to stage 'rfq'
        //     — so a rejected PR can't be laundered into a grandfathered one.
        //     Marking ordered/received requires an approved (or pre-gate) PO.
        (canPurchasing()
          && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(
                ['approvalStatus','approvedBy','approvedByName','approvedByTitle','approvedAt',
                 'rejectedBy','rejectedByName','rejectedAt','rejectedReason'])
              || request.resource.data.get('approvalStatus','') == 'pending'
              || (request.resource.data.get('approvalStatus','') == ''
                  && request.resource.data.get('stage','pr') == 'rfq'))
          && (!(request.resource.data.get('status','') in ['ordered','received'])
              || resource.data.get('approvalStatus','legacy') in ['approved','legacy']))
        // (b) President/Manager render the verdict — and may touch NOTHING else
        //     in the same write (can't rewrite items/prices under cover of approving).
        || (isSeniorAdmin() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(
              ['approvalStatus','approvedBy','approvedByName','approvedByTitle','approvedAt',
               'rejectedBy','rejectedByName','rejectedAt','rejectedReason','updatedAt']))
        // (c) Finance may ONLY stamp the bookkeeping fields (unchanged from pre-WS30).
        || (canFinance() && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['recordedToFinance','recordedToFinanceAt','recordedBy','recordedByName','cdjEntryId']))
      );
      allow delete: if isAuth() && (isPresident()
        || (canPurchasing() && resource.data.get('stage', 'rfq') == 'rfq'));
    }

    // ── Finance delete requests ────────────────────────
    // Finance staff file a request to delete any finance record; the President
    // approves/denies it (and performs the real delete) in the Approvals tab.
    match /finance_delete_requests/{docId} {
      allow read: if isAuth() && canFinance();
      allow create: if isAuth() && canFinance();
      allow update, delete: if isAuth() && isPresident();
    }

    // ── Bank accounts registry (v12 WS36) ──────────────
    // Master data for the company's cash locations (bank / e-wallet / petty cash).
    // Balances are DERIVED client-side (opening anchor + tagged ledger flows) — no
    // balance field lives here, so nothing a buggy writer could drift. Reads are
    // books-operators only (account numbers are sensitive); create/update is the
    // money tier (matches payroll/pay_runs post-WS19); deletes are President-only —
    // the client routes them through finance_delete_requests like every finance doc.
    match /bank_accounts/{docId} {
      allow read:   if isAuth() && canFinance();
      allow create, update: if isAuth() && isMoneyAdmin()
        && request.resource.data.get('nickname', '') is string
        && request.resource.data.get('nickname', '') != ''
        && request.resource.data.get('openingBalance', 0) is number
        && request.resource.data.get('type', 'bank') in ['bank', 'ewallet', 'cash'];
      allow delete: if isAuth() && isPresident();
    }

    // ── Payslips & Worker profiles (Brilliant Steel) ───
    match /payslips/{docId} {
      // v12 WS24 fix — the doc field written by collectPayslipData() is
      // `workerId`, never `userId`; the old rule checked a field that never
      // existed, so this owner-read branch was dead code (only finance/admin
      // could ever read a payslip). `.get(field, default)` per the
      // missing-field-denies hazard. `linkedUid` future-proofs WS20 D3's
      // worker_profiles bridge — harmless if never written.
      allow read: if isAuth() && (
        resource.data.get('workerId', '') == request.auth.uid ||
        resource.data.get('linkedUid', '') == request.auth.uid ||
        isFinanceOrAdmin()
      );
      allow create, update: if isAuth() && isFinanceOrAdmin();
      allow delete: if isAuth() && isPresident();
    }
    match /worker_profiles/{docId} {
      allow read: if isAuth() && isFinanceOrAdmin();
      allow create, update: if isAuth() && isFinanceOrAdmin();
      allow delete: if isAuth() && isPresident();
    }
    // ── Worker directory (public-safe roster projection, v12 WS28) ──
    // Mirror of worker_profiles holding ONLY assignment-safe fields (name, ID
    // number, job title, dept, status, photo) so Production staff can pick
    // per-stage workers WITHOUT read access to worker_profiles (rates/CA/SSS/
    // PhilHealth/TIN stay locked to finance/admin). docId == the worker_profiles
    // docId. Maintained by the HR profile save + the Sync Directory button.
    match /worker_directory/{docId} {
      allow read:           if isAuth() && !isPartner();
      allow create, update: if isAuth() && isFinanceOrAdmin();
      allow delete:         if isAuth() && isFinanceOrAdmin();
    }

    // ── Government biddings ────────────────────────────
    match /gov_biddings/{docId} {
      // Government bidding pipeline is internal-only — external partners excluded
      // from reading (null-safe getRole(): null is treated as "not partner").
      allow read: if isAuth() && !isPartner();
      allow write: if isAuth() && isAdmin();
    }

    // ── Departments config ─────────────────────────────
    // v12 WS19: read locked to !isPartner() — was bare isAuth().
    match /departments/{docId} {
      allow read: if isAuth() && !isPartner();
      allow write: if isAuth() && isAdmin();
    }

    // ── Inventory (raw materials + finished goods) ─────
    // Operational data for internal staff. Item costs are visible to staff;
    // external partners are excluded from reading/writing.
    match /inventory_items/{docId} {
      allow read:  if isAuth() && !isPartner();
      allow write: if isAuth() && !isPartner();
    }
    // Stock movement log — anyone internal can record in/out; only admins edit/delete history.
    match /stock_movements/{docId} {
      allow read:   if isAuth() && !isPartner();
      allow create: if isAuth() && !isPartner();
      allow update, delete: if isAuth() && isAdmin();
    }
    // Job costing carries revenue/margin per project — finance/admin only.
    match /job_costs/{docId} {
      allow read, write: if isAuth() && isFinanceOrAdmin();
    }

    // ── Production orders (shop-floor pipeline) ─────────
    // v12 WS28: writes scoped to the people who run the pipeline — Production
    // dept (or admins) manage orders; Sales may CREATE one (the "Job Order"
    // button on a project). Two transition gates are enforced server-side so a
    // devtools or stale-SW client can't skip them: entering Out for Delivery
    // needs a PASSED QC record; entering Delivered needs a delivery receipt.
    // Legacy pre-rename ids ('ready') are honoured in the transition checks so
    // routine edits to old docs aren't wrongly gated. Creating an order directly
    // in the last two stages is denied (only reachable through the gates).
    // Reads stay open to all internal staff (dashboards); only admins delete.
    match /production_orders/{docId} {
      allow read:   if isAuth() && !isPartner();
      allow create: if isAuth() && !isPartner() && (canProduction() || inDept('Sales'))
        && request.resource.data.get('stage','') != 'out_for_delivery'
        && request.resource.data.get('stage','') != 'delivered';
      allow update: if isAuth() && !isPartner() && canProduction()
        // QC gate — may not ENTER Out for Delivery without a passed inspection
        && ( request.resource.data.get('stage','') != 'out_for_delivery'
             || resource.data.get('stage','') in ['out_for_delivery','ready']
             || request.resource.data.get('qc', {}).get('result','') == 'passed' )
        // DR gate — may not ENTER Delivered without a delivery receipt
        && ( request.resource.data.get('stage','') != 'delivered'
             || resource.data.get('stage','') == 'delivered'
             || request.resource.data.get('deliveryReceipt', null) != null );
      allow delete: if isAuth() && isAdmin();
    }

    // ── Audit log (append-only) ─────────────────────────
    // Who-changed-what trail on sensitive mutations. A signed-in user may APPEND
    // an entry, but ONLY describing THEMSELVES (actorUid == their uid) with their
    // real role (actorRole == getRole()) and a server timestamp (no backdating) —
    // so entries can't be forged in another person's name. Entries are immutable
    // (no update); only the president may prune (e.g. clearing spam). Admins read.
    match /audit_log/{docId} {
      // v12 WS41: a user may list THEIR OWN trail (provable for
      // where('actorUid','==',uid) queries); admins read everything.
      // Create rule already forces actorUid == auth.uid, so "own" is sound.
      allow read:   if isAuth()
        && (isAdmin() || resource.data.get('actorUid','') == request.auth.uid);
      allow create: if isAuth()
        && request.resource.data.actorUid == request.auth.uid
        && request.resource.data.actorRole == getRole()
        && request.resource.data.ts == request.time
        && request.resource.data.keys().hasOnly(['ts','action','entity','entityId','details','actorUid','actorName','actorRole']);
      allow update: if false;
      allow delete: if isAuth() && isPresident();
    }

    // ── Leave requests ──────────────────────────────────
    // Employees file their own request (pending only) and read their own;
    // finance/admin read all + approve/reject; only the president deletes.
    match /leave_requests/{docId} {
      allow read: if isAuth() && (
        resource.data.userId == request.auth.uid || isFinanceOrAdmin()
      );
      // Shape-validate days/userName on every create; an employee may only file
      // their OWN request as pending. Finance/admin may file on anyone's behalf.
      allow create: if isAuth()
        && request.resource.data.days is number
        && request.resource.data.days > 0
        && request.resource.data.days <= 366
        && request.resource.data.userName is string
        && (
          isFinanceOrAdmin() ||
          (request.resource.data.userId == request.auth.uid
            && request.resource.data.status == 'pending')
        );
      // Only finance/admin may mutate a request after it's filed (approve/reject).
      // Employees never update — the client only ever creates — so the owner has
      // no update path (which would otherwise let them tamper post-approval).
      allow update: if isAuth() && isFinanceOrAdmin();
      allow delete: if isAuth() && isPresident();
    }

    // ── Sales orders (won project → payment → finance) ──
    // Anyone internal (incl. partners) can create an order for a project they
    // closed and read their own; finance/admin read all + update (post to books).
    match /sales_orders/{docId} {
      // Internal operational doc: any non-partner staff may read (so a Finance-dept
      // employee — role 'employee', not the special 'finance' role — can see them in
      // the Sales Orders tab). An unfiltered list query was being denied for such
      // users, which is why created orders "weren't reflecting". Partners only see
      // their own. Finance/admin still gate create→record (update).
      allow read:   if isAuth() && (
        resource.data.createdBy == request.auth.uid || !isPartner()
      );
      allow create: if isAuth() && request.resource.data.createdBy == request.auth.uid;
      allow update: if isAuth() && canFinance();
      allow delete: if isAuth() && isPresident();
    }

    // ── Project lifecycle (the spine: quote→order→production→delivery→paid) ──
    // Internal staff read + manage all; a partner sees only their own BS projects.
    match /job_projects/{docId} {
      // Partner sees projects they created OR shared projects originating from their quote.
      // Partner may NOT edit profit factors — only the project owner / non-partner staff can update.
      allow read:   if isAuth() && (resource.data.createdBy == request.auth.uid || resource.data.partnerUid == request.auth.uid || !isPartner());
      allow create: if isAuth() && request.resource.data.createdBy == request.auth.uid;
      // v12 WS36 — money keys need books access; stage/timeline/documents/tracking
      // edits stay open to internal staff exactly as before (affectedKeys diff, so
      // writes not touching money keys are unaffected).
      allow update: if isAuth() && (resource.data.createdBy == request.auth.uid || !isPartner())
        && ( !request.resource.data.diff(resource.data).affectedKeys().hasAny(
               ['payments', 'amountCollected', 'arBalance', 'invoices', 'dpPercent', 'balanceSchedule'])
             || canFinance() );
      allow delete: if isAuth() && isAdmin();
    }

    // ── Public order tracking (client-facing, PUBLIC read by unguessable token) ──
    // Each doc id is a random 20-char Firestore auto-id acting as an unguessable
    // access token — the shareable client link is /track.html?t={id}. `get` is
    // PUBLIC (no auth) so a client can open the link without an account; `list` is
    // DENIED so nobody can enumerate all orders. Only client-SAFE fields live here
    // (status, dates, amounts the client already knows) — never internal cost/margin.
    // Internal non-partner staff create/update it; admins may delete.
    match /order_tracking/{token} {
      allow get:    if true;
      allow list:   if false;
      allow create: if isAuth() && !isPartner();
      allow update: if isAuth() && !isPartner();
      allow delete: if isAuth() && isAdmin();
    }

    // ── Public ID verification (QR scan target, WS27) ───
    // Each doc id is an unguessable token; the public /v/?<token> page resolves
    // it. Holds ONLY a public-safe projection (name/photo/id-no/dept/title/
    // status) — NEVER SSS/PhilHealth/TIN/rates/CA/address/phone/email, which
    // stay in worker_profiles/users. `get` public, `list` denied (no enumeration).
    match /id_verify/{token} {
      allow get:  if true;
      allow list: if false;
      allow create, update: if isAuth() && !isPartner() && (
        isFinanceOrAdmin() ||                                     // HR mints worker + employee cards
        ( request.resource.data.get('kind','') == 'employee'      // employee self-mints OWN card only
          && request.resource.data.get('uid','') == request.auth.uid )
      );
      allow delete: if isAuth() && isAdmin();
    }

    // ── Leave balances (remaining day counters per user) ─
    // Kept in their own collection (NOT on the users doc) so finance can set
    // balances without being granted broad write access to user profiles.
    // The owner reads their own balance; finance/admin read all + write.
    match /leave_balances/{uid} {
      allow read:  if isAuth() && (isOwner(uid) || isFinanceOrAdmin());
      // Shape-guard so a buggy accrual run can't write NaN/negative/wrong-typed counters.
      // .get(field,default) — a missing field must not deny the rule (missing-field-throws memory).
      allow write: if isAuth() && isFinanceOrAdmin()
        && request.resource.data.get('vacation', 0) is number
        && request.resource.data.get('vacation', 0) >= 0
        && request.resource.data.get('sick', 0) is number
        && request.resource.data.get('sick', 0) >= 0;
    }

    // ── Leave accruals (annual grant idempotency key + forfeiture audit) ─
    // docId = {uid}_{YYYY}. Owner reads own history; finance/admin read all +
    // write (grant runs in admin context — employees never write). President-only delete.
    match /leave_accruals/{docId} {
      allow read:   if isAuth() && (resource.data.get('uid','') == request.auth.uid || isFinanceOrAdmin());
      allow create: if isAuth() && isFinanceOrAdmin()
        && request.resource.data.get('grantedVacation', 0) is number
        && request.resource.data.get('grantedVacation', 0) >= 0
        && request.resource.data.get('grantedSick', 0) is number
        && request.resource.data.get('grantedSick', 0) >= 0;
      allow update: if isAuth() && isFinanceOrAdmin();
      allow delete: if isAuth() && isPresident();
    }

    // ── Suggestions ────────────────────────────────────
    match /suggestions/{docId} {
      allow read: if isAuth() && isAdmin();
      allow create: if isAuth();
      allow update, delete: if isAuth() && isAdmin();
    }

    // ── Client CRM — UNIFIED (v12 WS32) ────────────────
    // ONE `clients` collection (brands[] tags Sales/Design/BS membership); the
    // three per-brand books below are read-only archives kept for the audit
    // trail. INTERNAL-ONLY: partners never read/write the client book — their
    // Client Data view derives from their own bs_quotes (already partner-scoped).
    // This deliberately closes the old hole where any BS partner could read the
    // ENTIRE bs_clients book. create/update require a non-empty string name via
    // .get(field,default) (missing-field-throws memory); note request.resource.data
    // is the full post-write doc, so field-patch updates still pass. DELETE is
    // admin-only — everyone else uses the deleteRequested flag (President queue).
    match /clients/{docId} {
      allow read:   if isAuth() && !isPartner();
      allow create, update: if isAuth() && !isPartner()
        && request.resource.data.get('name', '') is string
        && request.resource.data.get('name', '') != '';
      allow delete: if isAuth() && isAdmin();
    }
    // Legacy archives (records-forever directive): staff read, admin-only write
    // (migration stamps `migratedTo`), nothing else. Partner read of bs_clients
    // is REMOVED — no partner-facing code ever read it (grep-verified WS32 brief).
    match /sales_clients/{docId}  { allow read: if isAuth() && !isPartner(); allow write: if isAuth() && isAdmin(); }
    match /design_clients/{docId} { allow read: if isAuth() && !isPartner(); allow write: if isAuth() && isAdmin(); }
    match /bs_clients/{docId}      { allow read: if isAuth() && !isPartner(); allow write: if isAuth() && isAdmin(); }

    // ── Dynamic / runtime-named collections ────────────
    // The app creates per-scope and per-dept collections at runtime whose names
    // are not known ahead of time, so they can't be matched by literal name:
    //   files_<scope>  — uploaded documents (every Files tab, all depts)
    //   budgets_<dept> — budget allocation lines (Budgeting screens)
    // Firestore does NOT match collections by prefix, so cover each family with
    // a single-segment wildcard guarded by coll.matches(...). This only grants
    // access for those families; all explicitly-named collections above keep
    // their own (stricter) rules via the permissive union of matching rules.
    match /{coll}/{docId} {
      // Files: readable by internal staff; you own what you upload; owner/admin
      // edit or remove. v12 WS19: added !isPartner() — a files_* doc's `url`
      // field is a token-bearing Storage download link (js/drive.js), so letting
      // the external partner read it was a full file-content exfiltration path,
      // not just a metadata leak. Internal cross-department read stays open
      // (per-dept scoping would need a schema migration — deferred).
      allow read:   if isAuth() && coll.matches('files_.*') && !isPartner();
      allow create: if isAuth() && coll.matches('files_.*') && !isPartner()
                    && request.resource.data.uploadedBy == request.auth.uid;
      allow update, delete: if isAuth() && coll.matches('files_.*') && !isPartner()
                    && (resource.data.uploadedBy == request.auth.uid || isAdmin());
    }
    match /{coll}/{docId} {
      // Budget lines: internal planning data. v12 WS19: this was a genuine
      // world-write (any signed-in account, including a partner, could
      // create/update/delete ANY department's budget lines) — the UI's dept/
      // finance gating was cosmetic only. Read stays broad for internal staff;
      // write narrowed to money-tier (true per-department member-write would
      // need a fragile dept-string parse — deferred, finance/admin is the safe
      // close of the hole now).
      allow read:  if isAuth() && coll.matches('budgets_.*') && !isPartner();
      // v12 WS34: widened so a dept member can manage their OWN department's
      // budget lines (renderBudgeting's canEdit gate always showed them these
      // buttons; the rule silently denied — this closes that gap). Legacy lines
      // (no `dept` field) stay money-admin-only: .get('dept','') → inDept('')
      // is false, no backfill needed. create checks the incoming doc;
      // update/delete check the EXISTING doc so a member can't re-dept a line.
      allow create: if isAuth() && coll.matches('budgets_.*')
        && ( isMoneyAdmin()
          || (!isPartner() && inDept(request.resource.data.get('dept',''))) );
      allow update, delete: if isAuth() && coll.matches('budgets_.*')
        && ( isMoneyAdmin()
          || (!isPartner() && inDept(resource.data.get('dept',''))) );
    }

    // ── Files Hub (WS38) — unified file metadata + folder tree ─────────
    // Deliberately NOT named files_*: the files_.* wildcard above would
    // union-grant all-internal read and defeat per-file visibility/sharing.
    // Sharing enforcement uses ONLY uid arrays (sharedUserIds/editorUserIds)
    // — the canonical `uid in array` + array-contains-query pattern that
    // Firestore can prove for list queries. Dept/role shares are expanded
    // to uids client-side at share time. All .get(field, default) per the
    // missing-field-throws memory (migrated docs predate some fields).
    match /hub_files/{fileId} {
      allow read: if isAuth() && (
           isAdmin()
        || resource.data.get('uploadedBy','') == request.auth.uid
        || request.auth.uid in resource.data.get('sharedUserIds', [])
        || (!isPartner() && resource.data.get('visibility','company') == 'company')
      );
      allow create: if isAuth() && !isPartner()
        && request.resource.data.get('uploadedBy','') == request.auth.uid
        && request.resource.data.get('visibility','company') in ['company','private']
        && request.resource.data.get('deleted', false) == false;
      // Owner/admin: any update (incl. sharing/visibility). Editors: content &
      // organization fields only — NEVER the ACL/ownership fields.
      allow update: if isAuth() && (
           isAdmin()
        || resource.data.get('uploadedBy','') == request.auth.uid
        || (request.auth.uid in resource.data.get('editorUserIds', [])
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(
                 ['name','description','fileType','folderId','archived',
                  'deleted','deletedAt','deletedBy',
                  'url','driveUrl','size','contentType','versions','currentV',
                  'updatedAt']))
      );
      // Permanent delete = president only (Recycle Bin soft-delete/restore are updates).
      allow delete: if isAuth() && isPresident();
    }
    match /hub_folders/{folderId} {
      allow read:   if isAuth() && !isPartner();
      allow create: if isAuth() && !isPartner()
        && request.resource.data.get('createdBy','') == request.auth.uid;
      allow update, delete: if isAuth() && !isPartner()
        && (resource.data.get('createdBy','') == request.auth.uid || isAdmin());
    }
  }
}
